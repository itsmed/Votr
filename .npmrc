network-concurrency=4
child-concurrency=1

# Expo's Metro bundler resolves packages from within pnpm's virtual store
# (.pnpm/...) and cannot traverse back up to find hoisted deps. Hoisting
# everything avoids whack-a-mole resolution failures at the cost of pnpm's
# strict isolation (acceptable for a UI monorepo).
shamefully-hoist=true
